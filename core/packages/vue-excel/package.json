{
  "name": "@lucky-office/excel",
  "version": "0.2.0",
  "description": "基于 vue-office 二次开发的 Vue Excel 预览组件，支持 .xlsx/.xls 渲染、OLE 附件预览/下载/拖拽、单元格选择等能力。",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "scripts": {
    "clean": "shx rm -rf lib",
    "copyFile3": "shx cp lib/v3/lucky-office-excel.umd.js lib/index.js && shx cp src/index.css lib/index.css",
    "copyType": "shx cp index.d.ts lib/index.d.ts",
    "copyReadme": "shx cp README.md lib/README.md",
    "build": "npm run clean && vite build && npm run copyFile3 && npm run copyReadme && npm run copyType"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-template-literals": "^7.27.1",
    "@babel/preset-env": "^7.29.5",
    "@babel/runtime": "^7.23.6",
    "@rollup/plugin-babel": "^6.0.3",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/compiler-sfc": "3.2.45",
    "shx": "^0.3.4",
    "terser": "^5.47.1",
    "vite": "^8.0.12",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vue": "3.2.45"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZERO-WL/lucky-office.git",
    "directory": "core/packages/vue-excel"
  },
  "homepage": "https://github.com/ZERO-WL/lucky-office#readme",
  "bugs": {
    "url": "https://github.com/ZERO-WL/lucky-office/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "excel",
    "xlsx",
    "xls",
    "excel-preview",
    "lucky-office",
    "vue-office",
    "ole-attachment"
  ],
  "dependencies": {
    "@lucky-office/exceljs": "workspace:*",
    "jszip": "^3.10.1"
  },
  "license": "MIT",
  "author": "zhangwenli",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
