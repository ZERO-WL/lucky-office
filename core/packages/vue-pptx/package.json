{
  "name": "@lucky-office/pptx",
  "version": "0.1.0",
  "description": "基于 vue-office 二次开发的 Vue PPT（.pptx）预览组件。",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "scripts": {
    "clean": "shx rm -rf lib",
    "copyFile3": "shx cp lib/v3/lucky-office-pptx.umd.js lib/index.js",
    "copyType": "shx cp index.d.ts lib/index.d.ts",
    "copyReadme": "shx cp README.md lib/README.md",
    "build": "npm run clean && vite build && npm run copyFile3 && npm run copyReadme && npm run copyType"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/compiler-sfc": "3.2.45",
    "shx": "^0.3.4",
    "vite": "^8.0.12",
    "vue": "3.2.45"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:ZERO-WL/lucky-office.git"
  },
  "homepage": "https://github.com/ZERO-WL/lucky-office#readme",
  "bugs": {
    "url": "https://github.com/ZERO-WL/lucky-office/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "pptx",
    "ppt",
    "ppt-preview",
    "lucky-office",
    "vue-office"
  ],
  "license": "MIT",
  "author": "zhangwenli",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
