{
  "name": "@lucky-office/js-pdf",
  "type": "module",
  "version": "0.2.0",
  "description": "基于 vue-office 二次开发的框架无关 PDF 预览库（vanilla JS / UMD），底层基于 pdf.js。",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "scripts": {
    "clean": "shx rm -rf lib",
    "copyReadme": "shx cp README.md lib/README.md",
    "copyType": "shx cp index.d.ts lib/index.d.ts",
    "copy": "npm run copyType && npm run copyReadme",
    "build": "npm run clean && rollup --config rollup.config.js && npm run copy"
  },
  "devDependencies": {
    "shx": "^0.3.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZERO-WL/lucky-office.git",
    "directory": "core/packages/js-pdf"
  },
  "homepage": "https://github.com/ZERO-WL/lucky-office#readme",
  "bugs": {
    "url": "https://github.com/ZERO-WL/lucky-office/issues"
  },
  "keywords": [
    "pdf",
    "pdf-preview",
    "pdfjs",
    "lucky-office",
    "vue-office"
  ],
  "license": "MIT",
  "author": "zhangwenli",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {}
}
