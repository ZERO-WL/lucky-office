{
  "name": "lucky-office",
  "version": "1.0.0",
  "description": "基于 vue-office 二次开发的办公文档预览组件，支持 docx、pdf、ppt、excel 的预览",
  "scripts": {
    "dev": "node script/bak-vue.js && vite",
    "build": "node script/bak-vue.js && vite build",
    "lib": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/* build",
    "lib:js-excel": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/js-excel build",
    "lib:js-docx": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/js-docx build",
    "lib:vue-excel": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/excel build",
    "lib:vue-docx": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/docx build",
    "lib:js-pdf": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/js-pdf build",
    "lib:vue-pdf": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/pdf build",
    "lib:vue-pptx": "node script/bak-vue.js bak && pnpm run --filter @lucky-office/pptx build",
    "build:exceljs": "pnpm run --filter @lucky-office/exceljs build",
    "copy:exceljs": "node script/copy-exceljs.js",
    "release:dry": "node script/publish-all.js",
    "release": "node script/publish-all.js --release",
    "release:only": "node script/publish-all.js --skip-build"
  },
  "dependencies": {
    "@babel/plugin-transform-runtime": "^7.23.6",
    "@babel/plugin-transform-template-literals": "^7.23.3",
    "@babel/preset-env": "^7.22.5",
    "@babel/runtime": "^7.23.6",
    "@rollup/plugin-babel": "^6.0.3",
    "@vue/compiler-sfc": "3.2.45",
    "ant-design-vue": "^3.2.17",
    "core-js": "^3.37.1",
    "dayjs": "^1.11.7",
    "docx-preview": "^0.3.2",
    "lodash": "^4.17.21",
    "postcss": "^8.4.24",
    "rimraf": "^4.1.2",
    "rollup": "^3.26.0",
    "rollup-plugin-postcss": "^4.0.2",
    "tinycolor2": "^1.6.0",
    "vue-demi": "^0.14.6",
    "x-data-spreadsheet": "^1.1.9",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.2",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-terser": "^0.4.3",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/composition-api": "^1.7.1",
    "adm-zip": "^0.5.17",
    "eslint": "^8.36.0",
    "eslint-plugin-vue": "^9.9.0",
    "less": "^4.1.3",
    "less-loader": "^11.1.0",
    "pptx-preview": "^1.0.2",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-less": "^1.1.3",
    "rollup-plugin-node-resolve": "^5.2.0",
    "unzipper": "^0.10.14",
    "vite": "^5.4.11",
    "vite-plugin-require-transform": "^1.0.9",
    "vite-plugin-vue2": "^2.0.3",
    "vue": "3.2.45",
    "vue-router": "^4.6.4",
    "vue-template-compiler": "2.6.14",
    "vue2": "npm:vue@2.6.14",
    "vue3": "npm:vue@3.2.45"
  },
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:ZERO-WL/lucky-office.git"
  },
  "homepage": "https://github.com/ZERO-WL/lucky-office#readme",
  "bugs": {
    "url": "https://github.com/ZERO-WL/lucky-office/issues"
  },
  "keywords": [
    "vue",
    "docx",
    "pdf",
    "ppt",
    "excel",
    "docx-preview",
    "excel-preview",
    "pdf-preview",
    "lucky-office",
    "vue-office"
  ],
  "license": "MIT",
  "author": "zhangwenli",
  "private": true
}